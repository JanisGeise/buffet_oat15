FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

kInlet          8.79668;

internalField   uniform $kInlet;

boundaryField
{
    inlet_outlet
    {
        type            freestream;
        freestreamValue $internalField;
    }

    airfoil
    {
        type            fixedValue;
        value           uniform 0;
    }

    front
    {
        type            cyclic;
    }

    back
    {
        type            cyclic;
    }
    
    processor
    {
        type  processor;
        value $internalField;
    }

    processorCyclic
    {
        type  processorCyclic;
        value $internalField;
    }
}

