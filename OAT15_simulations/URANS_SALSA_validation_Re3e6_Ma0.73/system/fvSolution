FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-8;
        relTol          0.01;
        minIter         1;
    }

    pFinal
    {
        $p;
        relTol          0;
    }

    "(rho|k|omega|U|e|R|nuTilda)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0.01;
        minIter         1;
    }

    "(rho|k|omega|U|e|R|nuTilda)Final"
    {
        $U;
        relTol          0;
    }
}


PIMPLE
{
    momentumPredictor   yes;
    transonic           yes;
    nOuterCorrectors    25;
    nCorrectors         1;
    nNonOrthogonalCorrectors 2;
    consistent          yes;

    residualControl
    {
        "(U|p|e|nuTilda)"
        {
            relTol          0;
            tolerance       1.0e-5;
        }
    }
}

relaxationFactors
{ 
    equations
    {
        "(U|nuTilda|e|p|rho).*"     0.7;
    }
}

