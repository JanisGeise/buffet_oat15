FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 6.19016e-6;

boundaryField
{
    inlet_outlet
    {
        type            calculated;
        value           $internalField;
    }

    airfoil
    {
        type            fixedValue;
        value           uniform 0;
    }

    Front
    {
        type            cyclic;
    }

    Back
    {
        type            cyclic;
    }
}

