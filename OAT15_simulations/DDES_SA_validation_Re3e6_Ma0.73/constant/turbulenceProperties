FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  LES;

LES
{
    LESModel        SpalartAllmarasDDES;
    printCoeffs     yes;
    turbulence      yes;
    
    // https://www.openfoam.com/news/main-news/openfoam-v2412/solvers-and-physics
    SpalartAllmarasDDESCoeffs
    {
        shielding     ZDES2020;
        usefP2        true;
    }

    delta           DeltaOmegaTilde;
    DeltaOmegaTildeCoeffs
    {}
}

