FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      extrudeMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

constructFrom patch;

sourceCase ".";
sourcePatches (front);
exposedPatchName back;

flipNormals true;

extrudeModel        linearNormal;

nLayers         65;

linearNormalCoeffs
{
    thickness       0.25;
}

mergeFaces false;

// Merge small edges. Fraction of bounding box.
mergeTol 1e-8;

