FoamFile
{
    version     2.0;
    format      ascii;
    class       volSymmTensorField;
    object      R;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

Rinlet          (5.75 0 0 5.75 0 5.75);

internalField   uniform $Rinlet;

boundaryField
{
    inlet_outlet
    {
        type            freestream;
        freestreamValue $internalField;
    }

    airfoil
    {
        type            kqRWallFunction;
        value           uniform (0 0 0 0 0 0);
    }

    front
    {
        type empty;
    }

    back
    {
        type empty;
    }
}

