FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

epsilonInlet    27.70;

internalField   uniform $epsilonInlet;

boundaryField
{
    inlet_outlet
    {
        type            freestream;
        freestreamValue $internalField;
    }

    airfoil
    {
        type            epsilonWallFunction;
        value           uniform 28.58;
    }

    front
    {
        type empty;
    }

    back
    {
        type empty;
    }
}

