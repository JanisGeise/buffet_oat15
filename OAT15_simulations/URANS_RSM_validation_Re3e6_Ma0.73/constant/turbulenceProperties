FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  RAS;

RAS
{
    RASModel            LRR;
    turbulence          on;
    printCoeffs         on;

    // LRR specific
    wallReflection      false;       // true always crashes
    couplingFactor  0.0;        // default
}

