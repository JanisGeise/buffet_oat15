FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         backward;
}

gradSchemes
{
    default         Gauss linear;
    /*
    limited         cellLimited Gauss linear 0.5;
    grad(U)         $limited;
    grad(p)         $limited;
    grad(e)         $limited;
    grad(nuTilda)   $limited;
    grad(K)         $limited;
    grad(k)         $limited;
    grad(omega)     $limited;
    */
}

divSchemes
{
    default         none;

    div(phi,U)      Gauss limitedLinear 1;

    energy          Gauss limitedLinear 1;
    div(phi,e)      $energy;
    div(phi,K)      $energy;
    div(phi,Ekp)    $energy;

    turbulence       Gauss limitedLinear 1;
    div(phi,nuTilda) $turbulence;
    div(phi,k)       $turbulence;
    div(phi,omega)   $turbulence;

    div(phiv,p)     Gauss limitedLinear 1;
    div(phid,p)     Gauss limitedLinear 1;

    div(((rho*nuEff)*dev2(T(grad(U)))))    Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

wallDist
{
    method meshWave;
}

