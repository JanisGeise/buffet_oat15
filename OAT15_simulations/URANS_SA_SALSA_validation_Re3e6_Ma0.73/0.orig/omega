FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

omegaInlet      36.1;

internalField   uniform $omegaInlet;

boundaryField
{
    inlet_outlet
    {
        type            freestream;
        freestreamValue $internalField;
    }

    airfoil
    {
        type            fixedValue;
        value           uniform 1e10;
    }

    front
    {
        type            empty;
    }

    back
    {
        type            empty;
    }
    
    processor
    {
        type  processor;
        value $internalField;
    }
}

