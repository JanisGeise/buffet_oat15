FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     rhoPimpleFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         0.06;       // ~15 CTU -> begin of instability

deltaT          5e-7;

writeControl    adjustable;

writeInterval   1e-2;

purgeWrite      1;

writeFormat     binary;

writePrecision   8;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep  yes;

maxCo           0.95;

maxDeltaT       1e-6;

libs			("libSASALSACompressibleTurbulenceModel.so");

alpha           3.5;            // angle of attack
Uinlet          242.16629;      // free stream velocity
rho             0.957837;      // free stream density

functions
{
    pressure
    {
        type            pressure;
        libs            (fieldFunctionObjects);
        mode            totalCoeff;
        pInf            75230;
        rhoInf          $rho;

        Ux      #eval{$Uinlet * cos(degToRad($alpha))};
        Uz      #eval{$Uinlet * sin(degToRad($alpha))};

        UInf         ($Ux 0 $Uz);

        writeFields     false;
        executeControl  writeTime;
        executeInterval 1;
        writeControl    writeTime;
        writeInterval   1;
    }

    forces
    {
        type            forceCoeffs;
        libs            (forces);
        writeControl    timeStep;
        writeInterval   1;
        log             false;

        patches
        (
            airfoil
        );

        // taken from: https://develop.openfoam.com/Development/openfoam/-/blob/OpenFOAM-v2412/tutorials/incompressible/pimpleFoam/LES/NACA4412/system/forceCoeffs
        liftDir         (
                            #eval{-sin(degToRad($alpha))}
                            0 
                            #eval{cos(degToRad($alpha))}
                        );
        dragDir         (
                            #eval{cos(degToRad($alpha))}
                            0 
                            #eval{sin(degToRad($alpha))}
                        );
        pitchAxis   (0 1 0);
        CofR        (0.25 0 0); // center of rotation at 25% chord
        rhoInf      $rho;
        magUInf     $Uinlet;
        lRef        1;
        Aref        0.0375;   // projected area of the airfoil
    }

    Mach
    {
        type            MachNo;
        libs            (fieldFunctionObjects);
        field           U;
        log             true;
        executeControl  writeTime;
        executeInterval 1;
        writeControl    writeTime;
        writeInterval   1;
    }

    wallShearStress
    {
        type            wallShearStress;
        libs            (fieldFunctionObjects);
        patches         (airfoil);
        log             true;
        executeControl  writeTime;
        executeInterval 1;
        writeControl    writeTime;
        writeInterval   1;
    }
}

