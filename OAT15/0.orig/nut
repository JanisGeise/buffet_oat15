FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 1.5342e-5;

boundaryField
{
    outerBoundary
    {
        type            calculated;
        value           uniform 1.5342e-5;
    }

    airfoil
    {
        type            nutUSpaldingWallFunction;  // fixedValue;
        value           $internalField;		   // uniform 0;

    }

    Front
    {
        type            cyclic;
    }

    Back
    {
        type            cyclic;
    }
    
    processor
    {
        type  processor;
        value $internalField;
    }

    processorCyclic
    {
        type  processorCyclic;
        value $internalField;
    }
}

